# ============================================================
# AUTOPOST — Variáveis de ambiente
# Copie para .env.local (dev) e cadastre todas na Vercel (prod)
# ============================================================

# --- Segurança dos crons ---------------------------------------------------
# A Vercel envia automaticamente "Authorization: Bearer <CRON_SECRET>" nos crons.
# Gere um valor aleatório longo (ex.: `openssl rand -hex 32`).
CRON_SECRET=

# --- Google (Drive + Sheets + YouTube) --------------------------------------
# Criados no Google Cloud Console (veja README, passo 2).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Gerado rodando `npm run google-token` (veja README, passo 3).
GOOGLE_REFRESH_TOKEN=

# Pasta principal — vídeos aqui vão para TODAS as plataformas
# (está na URL da pasta: drive.google.com/drive/folders/<ESTE_ID>)
DRIVE_FOLDER_ID=

# Pastas dedicadas por plataforma (OPCIONAIS)
# Vídeos nestas pastas são publicados APENAS na plataforma correspondente.
# Deixe vazio se não usar. Você pode criar as pastas depois — só precisa
# preencher aqui quando quiser começar a usar cada uma.
DRIVE_FOLDER_ID_YT=
DRIVE_FOLDER_ID_IG=
DRIVE_FOLDER_ID_FB=
# Vídeos aqui vão SÓ pro TikTok. Diferente das outras 3, a pasta "Todas"
# NÃO inclui o TikTok automaticamente (ver README) — é preciso usar esta
# pasta dedicada ou editar a coluna `destinos` na planilha.
DRIVE_FOLDER_ID_TK=

# ID da planilha do Google Sheets que funciona como fila
# (está na URL: docs.google.com/spreadsheets/d/<ESTE_ID>/edit)
SHEET_ID=
# Nome da aba usada como fila
SHEET_TAB=Fila

# --- YouTube -----------------------------------------------------------------
# "public"  = publica na hora (exige projeto auditado pelo YouTube)
# "private" = sobe privado (comportamento padrão antes da auditoria)
# "unlisted" = não listado
YT_PRIVACY=public

# --- Anthropic (geração de títulos/descrições) -------------------------------
ANTHROPIC_API_KEY=
# Modelo usado na geração de metadados (pode trocar sem mexer no código)
CLAUDE_MODEL=claude-sonnet-4-6

# --- Groq (transcrição do áudio dos vídeos — OPCIONAL) -----------------------
# Sem esta chave, o pipeline usa apenas o nome do arquivo como dica pra IA.
# Com a chave, a IA gera títulos/descrições baseados no que você FALA no vídeo,
# muito melhor pra arquivos com nomes genéricos.
# Cadastro grátis em console.groq.com. Custo: ~US$ 0,04/hora de áudio
# (2000 requests/dia grátis — normalmente você nem sai do free tier).
GROQ_API_KEY=

# --- Twilio (avisos por SMS — OPCIONAL) ---------------------------------------
# Sem essas 4 variáveis, o pipeline funciona normal, só sem notificações.
# Cadastro em console.twilio.com (Account SID e Auth Token ficam na página
# inicial do console). Custo: alguns centavos por SMS enviado.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número Twilio que ENVIA o SMS (formato E.164, ex: +18445551234)
TWILIO_FROM_NUMBER=
# Número que RECEBE os avisos (formato E.164, ex: +5511999998888)
NOTIFY_PHONE_NUMBER=

# --- Meta (Instagram Reels + Página do Facebook) -----------------------------
# Token de longa duração da PÁGINA (com permissões pages_manage_posts,
# pages_read_engagement, instagram_basic, instagram_content_publish)
META_PAGE_ACCESS_TOKEN=
# ID da Página do Facebook do seu canal
FB_PAGE_ID=
# ID da conta PROFISSIONAL do Instagram vinculada à Página
IG_USER_ID=

# --- TikTok (Content Posting API — OPCIONAL) ----------------------------------
# Sem essas 3 variáveis, o TikTok não aparece como destino disponível.
# Cadastro em developers.tiktok.com. Gere o TIKTOK_REFRESH_TOKEN rodando
# `npm run tiktok-token` (veja README).
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=
# "SELF_ONLY" (padrão — obrigatório até a auditoria da TikTok aprovar o app)
# ou "PUBLIC_TO_EVERYONE" depois que aprovar.
TIKTOK_PRIVACY=SELF_ONLY

# --- Vercel Blob (hospedagem temporária do vídeo p/ a Meta puxar) ------------
# Criado automaticamente ao adicionar um Blob Store no projeto da Vercel.
BLOB_READ_WRITE_TOKEN=

# --- Comportamento ------------------------------------------------------------
# "true"  = publica direto, sem esperar você aprovar na planilha
# "false" = só publica linhas com status "aprovado" (recomendado no começo)
AUTO_APPROVE=false
